{
    "family": "multidocchat-task",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::178371639717:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::178371639717:role/ecsTaskRole",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "containerDefinitions": [
      {
        "name": "multidocchat-container",
        "image": "178371639717.dkr.ecr.us-east-1.amazonaws.com/multidocchat-repo",
        "cpu": 256,
        "essential": true,
        "portMappings": [
          {
            "containerPort": 8080,
            "hostPort": 8080,
            "protocol": "tcp",
            "name": "multidocchat-container-8080-tcp",
            "appProtocol": "http"
          },
          {
            "containerPort": 8081,
            "hostPort": 8081,
            "protocol": "tcp",
            "name": "multidocchat-container-8081-tcp",
            "appProtocol": "http"
          }
        ],
        "environment": [
          { "name": "ENV",           "value": "production" },
          { "name": "LLM_PROVIDER",  "value": "groq" },
          { "name": "AWS_REGION",    "value": "us-east-1" },
          { "name": "S3_BUCKET",     "value": "multidocchat-storage" },
          { "name": "DYNAMO_TABLE",  "value": "multidocchat-sessions" },
          { "name": "SQS_QUEUE_URL", "value": "https://sqs.us-east-1.amazonaws.com/178371639717/multidocchat-jobs" },
          { "name": "PINECONE_INDEX","value": "multidocchat" }
        ],
        "secrets": [
          {
            "name": "apikeyliveclass",
            "valueFrom": "arn:aws:secretsmanager:us-east-1:178371639717:secret:multidocchat-secrets-9yzC7K"
          },
          {
            "name": "PINECONE_API_KEY",
            "valueFrom": "arn:aws:secretsmanager:us-east-1:178371639717:secret:multidocchat-secrets-9yzC7K:PINECONE_API_KEY::"
          }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/multidocchat",
            "awslogs-region": "us-east-1",
            "awslogs-stream-prefix": "ecs",
            "awslogs-create-group": "true"
          }
        }
      }
    ]
  }
